{
  "name": "ai-news-agent",
  "version": "1.0.0",
  "description": "AI News Agent - 基于 CodeBuddy Agent SDK 的全自动 AI 资讯抓取客户端 (Web + Electron)",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "concurrently -k -n SERVER,CLIENT -c blue,green \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "tsx server/index.ts",
    "dev:client": "vite",
    "server": "tsx server/index.ts",
    "build:server": "esbuild server/index.ts --bundle --platform=node --packages=external --format=esm --outfile=dist-server/index.mjs --log-level=warning",
    "build": "vite build",
    "typecheck": "tsc -b",
    "preview": "vite preview",
    "electron:dev": "concurrently -k -n SERVER,ELECTRON -c blue,magenta \"npm run dev:server\" \"wait-on http://localhost:3000/api/health && electron .\"",
    "electron:build": "npm run build && npm run build:server && electron-builder",
    "dist": "npm run build && npm run build:server && electron-builder"
  },
  "dependencies": {
    "@tencent-ai/agent-sdk": "^0.3.43",
    "express": "^4.18.2",
    "fast-xml-parser": "^4.5.0",
    "lucide-react": "^0.563.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.10.0",
    "@types/react": "^18.2.43",
    "@types/react-dom": "^18.2.17",
    "@types/uuid": "^9.0.7",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.20",
    "concurrently": "^8.2.2",
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8",
    "esbuild": "^0.24.0",
    "postcss": "^8.5.0",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.6.2",
    "typescript": "^5.3.2",
    "vite": "^5.0.10",
    "wait-on": "^8.0.0"
  },
  "build": {
    "appId": "com.ainewsagent.app",
    "productName": "AI News Agent",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-server/**/*",
      "package.json"
    ],
    "extraMetadata": {
      "main": "electron/main.cjs"
    },
    "win": {
      "target": "nsis",
      "icon": "public/icon.ico"
    },
    "mac": {
      "target": "dmg",
      "category": "public.app-category.utilities"
    },
    "linux": {
      "target": "AppImage",
      "category": "Utility"
    }
  }
}
